# ─── Oracle Autonomous Database (26ai) ───────────────────────────────────────
# DB_USER: typically ADMIN for Always Free Tier
DB_USER=ADMIN

# DB_PASSWORD: the Admin password you set when creating the ADB instance
DB_PASSWORD=YourStrongPassword123!

# DB_DSN: the service name from tnsnames.ora — use the _high suffix for best performance
# Example: oracle26ai_high
DB_DSN=youratp_high

# WALLET_DIR: ABSOLUTE path to the extracted wallet directory (NOT relative)
# Wrong:  ./wallet           (will fail silently on some platforms)
# Right:  /Users/yourname/oracle-yt/wallet
WALLET_DIR=/absolute/path/to/oracle-yt/wallet

# WALLET_PASSWORD: the password you set when downloading the wallet zip
WALLET_PASSWORD=YourWalletPassword

# ─── LLM Provider — pick ONE ─────────────────────────────────────────────────
# Option A: OpenAI (GPT-4o) — recommended
OPENAI_API_KEY=sk-proj-...

# Option B: Cohere (Command R+) — free trial key available
# Uncomment and fill in if using Cohere instead of OpenAI
# COHERE_API_KEY=your-cohere-key-here
